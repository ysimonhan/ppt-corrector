# Bearer token required by the FastAPI backend on /jobs endpoints
API_KEY=replace_with_a_long_random_secret

# Langdock API credentials for Claude Sonnet 4.5 calls
LANGDOCK_API_KEY=replace_with_your_langdock_api_key
LANGDOCK_API_URL=https://api.langdock.com/anthropic/eu/v1/messages

# Runtime port used by Railway and local uvicorn
PORT=8000

# Optional override for the model used by the Langdock API client
# LANGDOCK_MODEL=claude-sonnet-4-5-20250929
