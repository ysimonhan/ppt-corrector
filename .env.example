# Required application credentials
API_KEY=replace_with_a_long_random_secret
LANGDOCK_API_KEY=replace_with_your_langdock_api_key

# Langdock LLM endpoint
LANGDOCK_API_URL=https://api.langdock.com/openai/eu/v1/chat/completions
LANGDOCK_MODEL=gpt-5.4
LLM_TIMEOUT_SECONDS=60
MIN_TEXT_LENGTH=3

# API runtime
PORT=8000
MAX_UPLOAD_SIZE_BYTES=52428800
DEFAULT_HIGHLIGHT_COLOR=FFFF00

# Local durable metadata store
DATABASE_URL=sqlite:///./ppt_corrector.db

# Job retention
JOB_TTL_SECONDS=3600
JOB_CLEANUP_INTERVAL_SECONDS=60
METADATA_RETENTION_SECONDS=604800

# Queue backend
QUEUE_BACKEND=inline
REDIS_URL=redis://localhost:6379/0
RQ_QUEUE_NAME=ppt-corrector

# Object storage backend
STORAGE_BACKEND=memory
S3_BUCKET=
S3_REGION=eu-central-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PREFIX=ppt-corrector
