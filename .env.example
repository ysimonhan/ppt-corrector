# Langdock API Key - get from https://app.langdock.com
LANGDOCK_API_KEY=your_api_key_here

# MCP Server Auth - set to protect the server (clients send Authorization: Bearer <key>)
# Leave empty or remove for local development (auth disabled)
MCP_API_KEY=

# Public URL for download links (required in production, e.g. Railway URL)
# Local dev default: http://localhost:8000
PUBLIC_URL=

# MCP Server Port (default: 8000)
MCP_PORT=8000
